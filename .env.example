# =============================================
# Karavali Lodge — Environment Template
# =============================================
# Copy this file to  .env  and fill in your values.
# The .env file is NOT committed to Git — this template is.
# =============================================

# ── Brevo (transactional email) ───────────────
# Sign up at: https://app.brevo.com
# API key:    app.brevo.com/settings/keys/api
# SMTP login: app.brevo.com/settings/keys/smtp
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your-login@smtp-brevo.com
BREVO_SMTP_PASS=your-smtp-key
BREVO_FROM_EMAIL=your@email.com
BREVO_FROM_NAME=Karavali Lodge
BREVO_API_KEY=xkeysib-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Admin ─────────────────────────────────────
ADMIN_NOTIFY_EMAIL=admin@gmail.com

# ── Database ──────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=karavali_lodge

# ── URLs ──────────────────────────────────────
BASE_URL=http://localhost/karavali_lodge

# ── Razorpay ──────────────────────────────────
# Get keys from: https://dashboard.razorpay.com/app/keys
# Use rzp_test_... for development, rzp_live_... for production
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXX
RAZORPAY_CURRENCY=INR
RAZORPAY_ADVANCE_PERCENT=1.00

# ── Environment ───────────────────────────────
# Use 'development' on localhost, 'production' on live server
APP_ENV=development
